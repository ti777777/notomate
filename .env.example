# Application Settings
APP_SECRET=
APP_DISABLE_SIGNUP=

# Collab Service
COLLAB_URL=http://127.0.0.1:3000

# Database Configuration (PostgreSQL)
# Leave commented to use default SQLite3
# DB_DRIVER=postgres
# DB_DSN=host=localhost port=5432 user=notomate password=notomate_password dbname=notomate sslmode=disable TimeZone=UTC

# Storage Configuration (S3/MinIO)
# Leave commented to use default local file storage
# STORAGE_TYPE=s3
# STORAGE_S3_ENDPOINT=localhost:9000
# STORAGE_S3_ACCESS_KEY=minioadmin
# STORAGE_S3_SECRET_KEY=minioadmin
# STORAGE_S3_BUCKET=notomate
# STORAGE_S3_USE_SSL=false

# AWS S3 Example
# STORAGE_TYPE=s3
# STORAGE_S3_ENDPOINT=s3.amazonaws.com
# STORAGE_S3_ACCESS_KEY=your_aws_access_key
# STORAGE_S3_SECRET_KEY=your_aws_secret_key
# STORAGE_S3_BUCKET=your-bucket-name
# STORAGE_S3_USE_SSL=true

# Workflow Runner
# Shared registration token for notomate-api and notomate-runner
# RUNNER_REGISTRATION_TOKEN=change-me

# gRPC address the runner (docker-compose.runner.yml) uses to reach the api.
# Defaults to host.docker.internal:50051 (api's published gRPC port on the
# same host). Set to a remote host:port if the runner runs elsewhere.
# NM_INSTANCE_ADDR=host.docker.internal:50051
