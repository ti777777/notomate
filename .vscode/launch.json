{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch API",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}\\api\\cmd\\api",
            "cwd": "${workspaceFolder}\\api",
            "envFile": "${workspaceFolder}\\.env",
            "env": {
                "DB_DSN": "../bin/notomate.db",
                "STORAGE_ROOT": "../bin/uploads/"
            }
        },
        {
            "name": "Launch Collab",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}\\collab\\src\\index.js",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}\\.env"
        }
    ],
    "compounds": [
        {
            "name": "Launch API + Collab",
            "configurations": ["Launch API", "Launch Collab"],
            "stopAll": true
        }
    ]
}